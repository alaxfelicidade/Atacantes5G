# index.html: nunca cacheado pelo CDN do Netlify
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# sw.js: nunca cacheado (essencial para updates do PWA)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets estáticos: cache longo (só mudam quando o nome muda)
/*.png
  Cache-Control: public, max-age=31536000, immutable
/manifest.json
  Cache-Control: public, max-age=86400
